---
layout: layouts/base.njk
---
<main class="article">
  <header class="art-hero" data-theme="dark">
    <a class="art-back" href="/articles/"><svg viewBox="0 0 24 24"><path d="M19 12H5M11 6l-6 6 6 6"/></svg> All articles</a>
    <span class="art-kicker">{{ tag }}</span>
    <h1>{{ artTitle | safe }}</h1>
    <div class="art-meta"><span>Precision Surfacing</span><span class="dot"></span><span>{{ readTime }}</span></div>
    {% if cover %}
    <div class="art-cover-wrap">
      <img class="art-cover" src="{{ cover }}" alt="{{ coverAlt }}" loading="lazy" decoding="async">
    </div>
    {% endif %}
  </header>

  <article class="art-body" data-theme="light">
    {{ content | safe }}
  </article>

  <section class="art-cta" data-theme="dark">
    <span class="art-kicker">Get started</span>
    <h2>Ready when <em>you are.</em></h2>
    <p>Tell us about your project and we'll come and measure up — no pressure, just an honest quote.</p>
    <a class="start-go" href="/get-started/">Start your free quote <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
  </section>
</main>

<style>
  .article{background:var(--paper,#EAEDEE)}
  /* ---- hero ---- */
  .art-hero{background:var(--ink,#0E0F10);color:#fff;padding:76px 22px 46px}
  .art-back{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono,"DM Mono",monospace);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.6);text-decoration:none;transition:color .2s ease}
  .art-back:hover{color:var(--gold-hl)}
  .art-back svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:1.8}
  .art-kicker{display:block;margin-top:30px;font-family:var(--mono,"DM Mono",monospace);font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:var(--gold)}
  /* the headline is the one place we still use the serif */
  .art-hero h1{font-family:var(--serif,"Instrument Serif",serif);font-weight:400;font-size:clamp(34px,8vw,56px);line-height:1.05;letter-spacing:.2px;margin:14px 0 0;max-width:18ch}
  .art-hero h1 em{font-style:italic;color:var(--gold-hl)}
  .art-meta{display:flex;align-items:center;gap:12px;margin-top:22px;font-family:var(--mono,"DM Mono",monospace);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.5)}
  .art-meta .dot{width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,.35)}
  /* ---- cover: contained, sits just below the headline, straddling the hero ---- */
  .art-cover-wrap{max-width:680px;margin-top:26px}
  .art-cover{display:block;width:100%;aspect-ratio:16/10;object-fit:cover;border-radius:14px;border:1px solid rgba(255,255,255,.07);box-shadow:0 20px 50px rgba(0,0,0,.4)}
  /* ---- body: sans-first, quiet typography ---- */
  .art-body{max-width:680px;margin:0 auto;padding:36px 22px 16px}
  .art-body .lead{font-family:var(--sans,"Inter",sans-serif);font-size:19px;line-height:1.6;font-weight:500;color:var(--graphite,#1B1D1E);margin-bottom:10px}
  .art-body .lead em{font-style:italic;color:var(--gold-deep)}
  .art-body h2{font-family:var(--sans,"Inter",sans-serif);font-weight:700;font-size:21px;line-height:1.25;letter-spacing:-.01em;color:var(--ink,#0E0F10);margin:34px 0 12px}
  .art-body p{font-family:var(--sans,"Inter",sans-serif);font-size:16.5px;line-height:1.75;color:#3c3f3e;margin-bottom:18px}
  .art-body strong{color:var(--ink,#0E0F10);font-weight:600}
  .art-body em{font-style:italic}
  .art-callout{background:#fff;border:1px solid rgba(14,15,16,.1);border-left:3px solid var(--gold-hl);border-radius:12px;padding:22px 24px;margin:32px 0}
  .art-callout h3{font-family:var(--mono,"DM Mono",monospace);font-size:10.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold-deep);margin-bottom:11px}
  .art-callout p{margin:0;font-family:var(--sans,"Inter",sans-serif);font-size:16px;line-height:1.7;color:#3c3f3e}
  /* ---- cta ---- */
  .art-cta{background:var(--ink,#0E0F10);color:#fff;text-align:center;padding:70px 22px 86px;margin-top:38px}
  .art-cta .art-kicker{color:var(--gold);margin-top:0}
  .art-cta h2{font-family:var(--serif,"Instrument Serif",serif);font-weight:400;font-size:clamp(30px,7vw,42px);line-height:1.08;margin:12px 0 14px}
  .art-cta h2 em{font-style:italic;color:var(--gold-hl)}
  .art-cta p{font-family:var(--sans,"Inter",sans-serif);color:rgba(255,255,255,.6);font-size:15.5px;line-height:1.6;max-width:44ch;margin:0 auto 30px}
  .art-cta .start-go{display:inline-flex;align-items:center;gap:10px;background:var(--gold-hl);color:var(--ink);text-decoration:none;font-family:var(--mono,"DM Mono",monospace);font-size:12px;letter-spacing:.12em;text-transform:uppercase;padding:16px 26px;border-radius:8px;transition:background .2s ease,transform .12s ease}
  .art-cta .start-go svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.9}
  .art-cta .start-go:hover{background:#F4D44A}
  .art-cta .start-go:active{transform:scale(.98)}

  @media (min-width:760px){
    .art-hero{padding:104px 50px 64px}
    .art-cover-wrap{margin-top:34px}
    .art-body{padding:48px 22px 20px}
    .art-body .lead{font-size:20px}
    .art-body h2{font-size:23px;margin-top:40px}
    .art-body p{font-size:17px}
  }
</style>
