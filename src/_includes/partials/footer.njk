{% set svc = services | sort(false, false, "order") %}
<footer class="site-footer">
  <div class="sf-inner">
    <div class="sf-brand">
      <div class="logo"><span class="logo-main">{{ site.logoMain }}</span><span class="logo-sub">{{ site.logoSub }}</span></div>
      <p class="sf-tag">Driveways &amp; surfacing across Norfolk<br>{{ site.locations }}</p>
    </div>
    <div class="sf-col">
      <span class="sf-h">Surfaces</span>
      {% for s in svc %}<a href="/services/{{ s.slug }}/">{{ s.navLabel }}</a>{% endfor %}
    </div>
    <div class="sf-col">
      <span class="sf-h">Company</span>
      <a href="/gallery/">Gallery</a>
      <a href="/articles/">Articles</a>
      <a href="/contact/">Contact</a>
      <a href="/get-a-quote/">Get a quote</a>
    </div>
    <div class="sf-col">
      <span class="sf-h">Get in touch</span>
      <a href="{{ site.phoneHref }}">{{ site.phone }}</a>
      <a href="mailto:{{ site.email }}">{{ site.email }}</a>
    </div>
  </div>
  <div class="sf-base">© <span id="yr"></span> {{ site.name }}. Four generations of Norfolk surfacing.</div>
</footer>
<style>
  /* margin-top:0 overrides the generic `footer{margin-top}` rule — that gap showed
     the darker body background above the footer, making it look mismatched. */
  .site-footer{background:var(--ink);color:#fff;padding:104px 22px 40px;margin-top:0;border-top:0}
  .sf-inner{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:1fr;gap:40px}
  .sf-brand .logo{display:flex;flex-direction:column;line-height:1}
  .sf-brand .logo-main{font-family:var(--font-logo,"Raleway",sans-serif);font-weight:600;font-size:22px;letter-spacing:5px;text-transform:uppercase;color:#fafafa}
  .sf-brand .logo-sub{font-family:var(--font-logo,"Raleway",sans-serif);font-weight:600;font-size:13px;letter-spacing:10px;text-transform:uppercase;color:var(--gold-hl);margin-top:3px}
  .sf-tag{margin-top:16px;color:rgba(255,255,255,.5);font-size:13px;line-height:1.6}
  .sf-col{display:flex;flex-direction:column;gap:11px}
  .sf-h{font-family:var(--mono,"DM Mono",monospace);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:4px}
  .sf-col a{color:rgba(255,255,255,.78);text-decoration:none;font-size:14px;transition:color .2s ease}
  .sf-col a:hover{color:var(--gold-hl)}
  .sf-base{max-width:1120px;margin:48px auto 0;padding-top:24px;border-top:1px solid rgba(255,255,255,.1);font-size:12px;color:rgba(255,255,255,.4)}
  @media (min-width:760px){.sf-inner{grid-template-columns:1.4fr 1fr 1fr 1fr;gap:48px}}
</style>
<script>document.getElementById('yr').textContent=new Date().getFullYear();</script>
