<style>
  .gallery{background:var(--paper,#EAEDEE)}
  /* ---- header ---- */
  .gal-head{background:var(--ink,#0E0F10);color:#fff;padding:84px 0 60px}
  .gal-head-in{max-width:1240px;margin:0 auto;padding:0 16px}
  .gal-head .kicker{color:var(--gold)}
  .gal-head h1{font-family:var(--serif,"Instrument Serif",serif);font-weight:400;font-size:clamp(38px,9vw,72px);line-height:1.02;margin:14px 0 16px}
  .gal-head h1 em{font-style:italic;color:var(--gold-hl)}
  .gal-head p{color:rgba(255,255,255,.62);max-width:52ch;font-size:16px}
  /* ---- body ---- */
  .gal-body{max-width:1240px;margin:0 auto;padding:26px 16px 90px}
  /* filter chips */
  .gal-filter{display:flex;flex-wrap:wrap;gap:9px;padding:8px 6px 22px}
  .fbtn{font-family:var(--mono,"DM Mono",monospace);font-size:11px;letter-spacing:.12em;text-transform:uppercase;
    color:var(--graphite,#1B1D1E);background:transparent;border:1px solid rgba(14,15,16,.2);border-radius:30px;
    padding:9px 15px;cursor:pointer;transition:background .18s ease,color .18s ease,border-color .18s ease}
  .fbtn:hover{border-color:rgba(14,15,16,.5)}
  .fbtn.is-on{background:var(--ink,#0E0F10);border-color:var(--ink,#0E0F10);color:var(--gold-hl,#F0CC3A)}
  /* masonry grid */
  .gal-grid{columns:2;column-gap:14px}
  .gal{break-inside:avoid;display:block;width:100%;margin:0 0 14px;padding:0;border:0;background:#1c1c1d;
    border-radius:14px;overflow:hidden;position:relative;cursor:pointer;line-height:0;
    box-shadow:0 1px 2px rgba(14,15,16,.05);transition:transform .3s cubic-bezier(.22,1,.36,1),box-shadow .3s ease}
  .gal.hide{display:none}
  .gal img{width:100%;height:auto;display:block;transition:transform .5s cubic-bezier(.22,1,.36,1)}
  .gal-cap{position:absolute;left:0;right:0;bottom:0;display:flex;flex-direction:column;gap:2px;
    padding:34px 14px 12px;text-align:left;line-height:1.3;
    background:linear-gradient(to top,rgba(8,9,10,.82),rgba(8,9,10,0));
    opacity:0;transform:translateY(6px);transition:opacity .3s ease,transform .3s ease}
  .gal-cap b{font-family:var(--font-logo,"Raleway",sans-serif);font-weight:600;font-size:13px;letter-spacing:.06em;color:#fff}
  .gal-cap i{font-family:var(--mono,"DM Mono",monospace);font-style:normal;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold-hl,#F0CC3A)}
  .gal:hover{transform:translateY(-3px);box-shadow:0 16px 34px -14px rgba(14,15,16,.45)}
  .gal:hover img{transform:scale(1.05)}
  .gal:hover .gal-cap,.gal:focus-visible .gal-cap{opacity:1;transform:none}
  .gal-empty{padding:30px 6px;color:var(--mist,#7E817A);font-size:15px}
  .gal-empty a{color:var(--gold-deep)}
  /* ---- closing cta ---- */
  .gal-cta{text-align:center;padding:64px 20px 8px;margin-top:20px;border-top:1px solid rgba(14,15,16,.1)}
  .gal-cta h2{font-family:var(--serif,"Instrument Serif",serif);font-weight:400;font-size:clamp(30px,7vw,42px);color:var(--ink,#0E0F10);margin-bottom:10px}
  .gal-cta h2 em{font-style:italic;color:var(--gold-deep)}
  .gal-cta p{color:#55585a;font-size:15.5px;line-height:1.6;max-width:42ch;margin:0 auto 26px}
  .gal-cta .start-go{display:inline-flex;align-items:center;gap:10px;background:var(--gold-hl);color:var(--ink);text-decoration:none;font-family:var(--mono,"DM Mono",monospace);font-size:12px;letter-spacing:.12em;text-transform:uppercase;padding:16px 26px;border-radius:8px;transition:background .2s ease,transform .12s ease}
  .gal-cta .start-go svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.9}
  .gal-cta .start-go:hover{background:#F4D44A}
  .gal-cta .start-go:active{transform:scale(.98)}
  /* ---- lightbox ---- */
  .glb{position:fixed;inset:0;z-index:80;background:rgba(8,8,9,.96);-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);
    display:flex;flex-direction:column;opacity:0;visibility:hidden;transition:opacity .3s ease,visibility .3s ease}
  .glb.on{opacity:1;visibility:visible}
  .glb-x{align-self:flex-end;margin:18px 20px 0;background:none;border:0;cursor:pointer;color:rgba(255,255,255,.6);font-family:var(--mono,"DM Mono",monospace);font-size:12px;letter-spacing:.14em}
  .glb-x:hover{color:var(--gold-hl)}
  .glb-stage{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;min-height:0;padding:6px 8px}
  .glb-fig{margin:0;max-width:92vw;max-height:78vh;display:flex}
  .glb-fig img{max-width:92vw;max-height:78vh;width:auto;height:auto;object-fit:contain;border-radius:6px;display:block}
  .glb-arrow{flex:0 0 auto;background:none;border:0;padding:6px;cursor:pointer}
  .glb-arrow svg{width:30px;height:30px;stroke:#fff;fill:none;stroke-width:2;filter:drop-shadow(0 1px 4px rgba(0,0,0,.7));display:block;transition:stroke .2s ease}
  .glb-arrow:hover svg{stroke:var(--gold-hl)}
  .glb-cap{text-align:center;padding:14px 20px 26px;font-family:var(--mono,"DM Mono",monospace);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.7)}

  @media (min-width:680px){ .gal-grid{columns:2;column-gap:18px} .gal{margin-bottom:18px} }
  @media (min-width:1040px){ .gal-grid{columns:3;column-gap:20px} }
  @media (min-width:760px){
    .gal-head{padding:118px 0 74px}
    .gal-head-in{padding:0 40px}
    .gal-body{padding:30px 40px 110px}
    .glb-x{margin:22px clamp(28px,4vw,56px) 0}
  }
</style>

<script>
  (function(){
    var grid=document.getElementById('galGrid'); if(!grid) return;
    var tiles=[].slice.call(grid.querySelectorAll('.gal'));
    var fbtns=[].slice.call(document.querySelectorAll('.fbtn'));
    var empty=document.getElementById('galEmpty');
    function apply(f){
      fbtns.forEach(function(b){b.classList.toggle('is-on', b.dataset.filter===f);});
      var shown=0;
      tiles.forEach(function(t){ var hide = f!=='all' && t.dataset.cat!==f; t.classList.toggle('hide',hide); if(!hide)shown++; });
      if(empty) empty.hidden = shown>0;
    }
    fbtns.forEach(function(b){ b.addEventListener('click',function(){ apply(b.dataset.filter); }); });

    var glb=document.getElementById('glb'), gimg=document.getElementById('glbImg'), gcap=document.getElementById('glbCap');
    var prev=document.getElementById('glbPrev'), next=document.getElementById('glbNext');
    var cur=-1;
    function visible(){ return tiles.filter(function(t){ return !t.classList.contains('hide'); }); }
    function paint(vis){ var t=vis[cur]; if(!t) return; var im=t.querySelector('img'); gimg.src=im.currentSrc||im.src; gimg.alt=im.alt; gcap.textContent=t.dataset.cap; }
    function open(t){ var vis=visible(); cur=vis.indexOf(t); paint(vis); glb.classList.add('on'); glb.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
    function close(){ glb.classList.remove('on'); glb.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
    function step(d){ var vis=visible(); if(!vis.length) return; cur=(cur+d+vis.length)%vis.length; paint(vis); }
    tiles.forEach(function(t){ t.addEventListener('click',function(){ open(t); }); });
    document.getElementById('glbX').addEventListener('click',close);
    prev.addEventListener('click',function(e){ e.stopPropagation(); step(-1); });
    next.addEventListener('click',function(e){ e.stopPropagation(); step(1); });
    glb.addEventListener('click',function(e){ if(!e.target.closest('.glb-fig') && !e.target.closest('button')) close(); });
    document.addEventListener('keydown',function(e){ if(!glb.classList.contains('on')) return; if(e.key==='Escape')close(); if(e.key==='ArrowLeft')step(-1); if(e.key==='ArrowRight')step(1); });
    var tx=0;
    glb.addEventListener('touchstart',function(e){ tx=e.changedTouches[0].clientX; },{passive:true});
    glb.addEventListener('touchend',function(e){ var dx=e.changedTouches[0].clientX-tx; if(Math.abs(dx)>45) step(dx<0?1:-1); },{passive:true});
  })();
</script>
